<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ERV" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/erv_primary</item>
        <item name="colorOnPrimary">@color/erv_on_primary</item>
        <item name="colorSurface">@color/erv_surface</item>
        <item name="colorOnSurface">@color/erv_on_surface</item>
    </style>

    <!-- No floating dialog window: bubbles embed the activity; windowIsFloating caused crashes on some OEMs. -->
    <style name="Theme.ERV.Bubble" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
