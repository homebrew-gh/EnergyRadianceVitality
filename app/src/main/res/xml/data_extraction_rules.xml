<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Keep ERV data out of Android 12+ cloud backup and device-to-device transfer. -->
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
